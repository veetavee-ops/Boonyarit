# Environment Variables Configuration

# ===== LINE Bot Configuration =====
CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
CHANNEL_SECRET=your_line_channel_secret_here

# ===== Server Configuration =====
PORT=3000
NODE_ENV=development

# ===== Database Configuration =====
# Option 1: Use connection string (recommended for production)
# DATABASE_URL=postgresql://username:password@host:port/database
# DB_SSL=true

# Option 2: Use individual credentials (recommended for development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=line_archive
DB_USER=postgres
DB_PASSWORD=postgres

# ===== Authentication =====
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# ===== AI Service (Google Gemini) =====
GEMINI_API_KEY=your_gemini_api_key_here

# ===== Frontend URL (for CORS) =====
FRONTEND_URL=http://localhost:5173
